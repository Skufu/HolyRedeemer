# =============================================================================
# Holy Redeemer Library API - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to version control!

# =============================================================================
# Server Configuration
# =============================================================================
PORT=8080
ENVIRONMENT=development

# =============================================================================
# Database Configuration
# =============================================================================
# PostgreSQL connection string
# For Neon: postgres://user:password@host.neon.tech/dbname?sslmode=require
# For local: postgres://postgres:postgres@localhost:5432/library_dev?sslmode=disable
DATABASE_URL=postgres://postgres:postgres@localhost:5432/library_dev?sslmode=disable

# =============================================================================
# JWT Configuration
# =============================================================================
# IMPORTANT: Generate secure secrets for production!
# Run: openssl rand -base64 32
JWT_ACCESS_SECRET=your-super-secret-access-key-change-in-production
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production

# Token expiry times (Go duration format)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=168h

# =============================================================================
# CORS Configuration
# =============================================================================
# Comma-separated list of allowed origins
# Example: http://localhost:3000,https://your-frontend.vercel.app
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# Library Settings (Defaults)
# =============================================================================
# These are default values used when library_settings table is empty

# Number of days for standard loan period
DEFAULT_LOAN_DAYS=14

# Maximum books a student can borrow at once
DEFAULT_MAX_BOOKS=5

# Fine amount per day for overdue books (in pesos)
DEFAULT_FINE_PER_DAY=5.0

# Grace period before fines start (days)
DEFAULT_GRACE_PERIOD=1

# Maximum fine cap per book (in pesos)
DEFAULT_MAX_FINE_CAP=500.0

# Outstanding fine threshold that blocks borrowing (in pesos)
DEFAULT_BLOCK_THRESHOLD=100.0
