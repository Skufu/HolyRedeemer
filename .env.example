# Holy Redeemer Library Management System - Frontend Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env file to version control!
#
# =============================================================================
# API Configuration
# =============================================================================
# Backend API base URL
# Development: http://localhost:8080
# Production: https://api.holyredeemer-library.com
VITE_API_URL=http://localhost:8080

# =============================================================================
# Feature Flags
# =============================================================================
# Enable mock data for development (set to false for production)
VITE_ENABLE_MOCK_DATA=false

# Enable debug mode (shows additional console logs)
VITE_DEBUG_MODE=false

# =============================================================================
# Application Settings
# =============================================================================
# Application title
VITE_APP_TITLE=Holy Redeemer Library

# School name
VITE_SCHOOL_NAME=Holy Redeemer School of Cabuyao

# Library name
VITE_LIBRARY_NAME=Holy Redeemer School Library
